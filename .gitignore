# EventEase .gitignore

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Environments & Virtual Envs
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Flask Transient Files
flask_session/

# Dynamic User Uploads & Generated QR Tickets
static/uploads/banners/*
!static/uploads/banners/.gitkeep
static/uploads/avatars/*
!static/uploads/avatars/.gitkeep
static/qr_tickets/*
!static/qr_tickets/.gitkeep

# IDEs & System files
.vscode/
.idea/
.DS_Store
Thumbs.db
desktop.ini
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
